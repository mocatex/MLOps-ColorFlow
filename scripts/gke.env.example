PROJECT_ID=project-id
REGION=europe-west6
REPOSITORY=colorflow
IMAGE_TAG=latest
# Leave APP_HOST empty to expose the app directly on the load balancer IP.
APP_HOST=
MLFLOW_ARTIFACT_STORAGE_MODE=bucket
MLFLOW_ARTIFACT_ROOT=/outputs/mlruns
MLFLOW_ARTIFACT_BUCKET=mlops-flow
COLORFLOW_CHECKPOINT_BUCKET=mlops-checkpoints
# For filesystem mode, point these at your Filestore or other NFS share instead.
# MLFLOW_ARTIFACT_STORAGE_MODE=filesystem
# MLFLOW_ARTIFACT_ROOT=/outputs/mlruns
# MLFLOW_ARTIFACT_NFS_SERVER=10.0.0.2
# MLFLOW_ARTIFACT_NFS_PATH=/colorflow
# MLFLOW_ARTIFACT_PVC_SIZE=10Gi
GCP_SERVICE_ACCOUNT_EMAIL=colorflow-runtime@project-id.iam.gserviceaccount.com
